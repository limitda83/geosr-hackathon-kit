# 제출 폴더는 git에 올리지 않음 (별도 zip으로 제출)
submit/

# API 키
.env
.env.*
.streamlit/secrets.toml

# 대용량 데이터 (SST 등)
data/raw/
*.nc
*.nc.part

# 단, 결과 성과물 nc 는 git 에 보관 (원자료 data/input 의 nc 는 계속 제외)
!data/results/**/*.nc

# 로컬 설정 / 캐시 / OS 부산물
.claude/
__pycache__/
*.pyc
.DS_Store

# 환경변수 / 비밀키 (SST API 키 등 — 절대 커밋 금지)
.env
*.env

# 로그
*.log




